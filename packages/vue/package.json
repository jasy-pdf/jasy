{
  "name": "@jasy/vue",
  "version": "1.0.0-alpha.4",
  "description": "Author PDFs as Vue components - a thin Vue custom renderer over @jasy/pdf.",
  "keywords": [
    "declarative",
    "invoice",
    "jasy",
    "pdf",
    "pdf-generation",
    "renderer",
    "vue",
    "vue3"
  ],
  "license": "MIT",
  "author": "Florian Heuberger",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "prepack": "pnpm run build",
    "play": "vite playground --open",
    "test": "vitest run"
  },
  "dependencies": {
    "@jasy/pdf": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@vitejs/plugin-vue": "^5.2.1",
    "typescript": "^5.6.0",
    "vite": "^6.3.4",
    "vue": "^3.5.13",
    "vue-pdf-embed": "^2.1.5"
  },
  "peerDependencies": {
    "vue": "^3.4.0"
  }
}
