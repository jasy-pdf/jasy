{
  "name": "@jasy/cli",
  "version": "0.0.1",
  "description": "Interactive terminal to validate, read and export ZUGFeRD / XRechnung e-invoices.",
  "keywords": [
    "cli",
    "e-invoice",
    "tui",
    "validator",
    "xrechnung",
    "zugferd"
  ],
  "license": "MIT",
  "author": "Florian Heuberger",
  "bin": {
    "jasy": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "watch": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@jano-editor/ui": "1.0.0-alpha.7",
    "@jasy/zugferd": "workspace:*",
    "saxon-js": "^2.6.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "tsx": "^4.19.2"
  }
}
